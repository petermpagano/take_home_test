# Copy this file to .env.local and fill in your key.
# .env.local is gitignored — never commit a real key.

# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the vision model. Defaults to claude-sonnet-4-6,
# chosen for its speed/quality balance to meet the <5s review target.
# ANTHROPIC_MODEL=claude-sonnet-4-6
